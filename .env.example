# ── Supabase (Backend) ────────────────────────────────────────────────────────
# Your Supabase project URL (from Project Settings → API)
SUPABASE_URL=

# Your Supabase service role key (keep this secret, never expose in the browser)
SUPABASE_KEY=

# ── API Security (Frontend & Backend) ─────────────────────────────────────────
# A strong random secret key to authenticate frontend requests to the backend.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Both the frontend and backend will use this same key to communicate.
API_SECRET_KEY=

# ── EmailJS (Frontend) ────────────────────────────────────────────────────────
# Your EmailJS credentials (these have default fallbacks in the code)
EMAILJS_SERVICE_ID=service_az4400a
EMAILJS_TEMPLATE_ID=template_ove2j9k
EMAILJS_PUBLIC_KEY=-WSr2Zox6TnvX7osv
